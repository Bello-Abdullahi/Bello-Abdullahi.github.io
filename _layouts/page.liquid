---
layout: default
---
<!-- _layouts/page.html (or page.liquid) -->
<div class="post">

  <header class="post-header" style="border-bottom: 2px solid #B5121B; padding-bottom: 0.75rem; margin-bottom: 2rem;">
    <h1 class="post-title" style="margin-bottom: 0.25rem;">{{ page.title }}</h1>
    {% if page.description %}
      <p class="post-description" style="color: var(--muted); font-style: italic; margin: 0;">
        {{ page.description }}
      </p>
    {% endif %}
  </header>

  <article>
    {{ content }}
  </article>

</div>
